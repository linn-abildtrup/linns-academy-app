rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		// Admin-emails. Skal matche listen i src/lib/admin.ts.
		// Tilføj her hvis flere skal kunne redigere indhold fra UI'et.
		function isAdmin() {
			return request.auth != null
				&& request.auth.token.email in [
					'linnabildtrup00@gmail.com'
				];
		}

		// Bruger-dokument:
		//   - Ejeren kan læse og skrive sit eget
		//   - Admin kan læse alle brugere (til admin-overblik i Abonnenter-siden)
		match /users/{uid} {
			allow read: if request.auth != null && (isAdmin() || request.auth.uid == uid);
			allow write: if request.auth != null && request.auth.uid == uid;

			// Bruger-produkter (køb, fremgang, valg): kun egen bruger
			match /products/{productId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;

				// Vanedage på et produkt: kun egen bruger
				match /vanedage/{dagId} {
					allow read, write: if request.auth != null && request.auth.uid == uid;
				}
			}

			// Pause-state for igangværende træning: kun egen bruger
			match /pauses/{pauseId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Dagbog — gemte måltider fra 30-30-3-beregneren: kun egen bruger
			match /maaltider/{mealId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Favoritmåltider — skabeloner til hurtig genbrug: kun egen bruger
			match /favoritmaaltider/{favId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Egne fødevarer — kundens private fødevarer (fra scanner eller
			// manuelt tilføjet). Kun egen bruger har read/write.
			match /customFodevarer/{foodId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Vanedage på userProduct: kun egen bruger (samme regel som pauses)
			// Stien er users/{uid}/products/{productId}/vanedage/{dagId} så
			// reglen ligger på products-niveau længere nede.

			// Admin-klient-mode: når Linn bruger 'Skift til klient'-knappen
			// gemmes klient-test-data under users/{uid}/adminKlient/{forlobId}/...
			// Det er stadig hendes egne data, så samme regel: kun ejeren kan
			// læse/skrive. Wildcard {document=**} dækker alle nestede paths.
			match /adminKlient/{forlobId}/{document=**} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Abo-vanetracker — brugerens valgte vaner (single doc 'aktiv')
			match /aboVaneOpsaetning/{docId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Abo-vanetracker — daglige svar pr dato (YYYY-MM-DD som doc-id)
			match /aboVanedage/{dato} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Abo-mikrotræning — brugerens fremgang (single doc 'aktiv')
			match /aboMikrotraeningFremgang/{docId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Abo-mikrotræning — historik pr dato (YYYY-MM-DD som doc-id)
			match /aboMikrotraeningTraeninger/{dato} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Linn AI — brugerens chat-samtaler (premium-feature)
			match /linnAiSamtaler/{samtaleId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Linn AI — daglig query-quota (rate-limit-tæller)
			match /linnAiQuotaer/{dato} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}

			// Private opskrifter — klientens egne opskrifter med makro fra AI-vision
			match /privateOpskrifter/{opskriftId} {
				allow read, write: if request.auth != null && request.auth.uid == uid;
			}
		}

		// Øvelsesbibliotek: alle autentificerede kan læse, kun admin kan skrive
		match /exercises/{exerciseId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Træningsprogrammer + deres dage: alle autentificerede kan læse, kun admin kan skrive
		match /trainingPrograms/{programId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();

			match /days/{dayId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}
		}

		// Produkter (Kickstart osv.): alle autentificerede kan læse, kun admin kan skrive
		match /products/{productId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Fødevaredatabase (840+ items): alle autentificerede kan læse,
		// kun admin kan skrive. Klienten cacher hele databasen ved første load.
		match /fodevarer/{fodevareId} {
			allow read: if request.auth != null;
			// Admin må alt
			allow write: if isAdmin();
			// Logget-ind brugere må oprette community-fødevarer (cf_-prefix)
			// så længe addedBy matcher dem selv, kilde er 'community', og
			// scanner-brugeren er i okBy som første stem.
			allow create: if request.auth != null
				&& fodevareId.matches('cf_.*')
				&& request.resource.data.kilde == 'community'
				&& request.resource.data.addedBy == request.auth.uid
				&& request.resource.data.okBy is list
				&& request.resource.data.okBy.size() == 1
				&& request.resource.data.okBy[0] == request.auth.uid;
			// Logget-ind brugere må stemme på community-fødevarer ved at
			// opdatere okBy / ejBy / verificeret. Andre felter må ikke ændres.
			allow update: if request.auth != null
				&& fodevareId.matches('cf_.*')
				&& resource.data.kilde == 'community'
				&& request.resource.data.diff(resource.data).affectedKeys()
					.hasOnly(['okBy', 'ejBy', 'verificeret']);
		}

		// Opskrifter: alle autentificerede kan læse, kun admin kan skrive.
		match /opskrifter/{opskriftId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Forløb (kohorter med startdato + whitelist): alle autentificerede kan læse,
		// kun admin kan skrive. Klienten har brug for at læse for at vise startdato.
		match /forlob/{forlobId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();

			// Vaneprogram pr forløb: alle autentificerede kan læse (klienten skal
			// se spørgsmålene), kun admin kan skrive.
			match /vaneprogram/{dagId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}

			// Forløbsdage pr forløb (lektioner + note fra Linn pr dagNummer):
			// alle autentificerede kan læse, kun admin kan skrive.
			match /forlobsdage/{dagId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}

			// Mikrotræningsprogrammer pr forløb: program-metadata + dage som
			// subcollection. Alle autentificerede kan læse (klient skal se
			// program og dage), kun admin kan skrive.
			match /mikrotraeningProgrammer/{programId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();

				match /days/{dagId} {
					allow read: if request.auth != null;
					allow write: if isAdmin();
				}
			}

			// Bibliotek pr forløb — FAQ-kategorier: alle autentificerede kan læse,
			// kun admin kan skrive. Klient-koden filtrerer på udgivet-flag.
			match /faqKategorier/{kategoriId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}

			// Bibliotek pr forløb — FAQ-items: samme regel som kategorier.
			match /faqItems/{itemId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}

			// Bibliotek pr forløb — guide-kategorier: samme mønster som FAQ.
			match /guideKategorier/{kategoriId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}

			// Bibliotek pr forløb — guide-items: samme mønster som FAQ.
			match /guideItems/{itemId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}
		}

		// Abo-vanetracker — kurateret vaneliste pr produkttype (basis/premium):
		// alle autentificerede kan læse (klient skal se forslag), kun admin skriver.
		match /aboVaneskabelon/{produktType} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Abo-vanetracker — bonus-pulje pr produkttype:
		// alle autentificerede kan læse, kun admin skriver.
		match /aboBonusPulje/{produktType} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Abo-mikrotræning — program-metadata pr produkttype:
		// alle autentificerede kan læse, kun admin skriver.
		match /aboMikrotraening/{produktType} {
			allow read: if request.auth != null;
			allow write: if isAdmin();

			// Træningsdage 1-14 under hver produkttype
			match /days/{dagId} {
				allow read: if request.auth != null;
				allow write: if isAdmin();
			}
		}

		// Modulbruger-lektioner — daglig lektion på modulbruger-forsiden.
		// Doc-id er YYYY-MM-DD. Alle autentificerede kan læse (vises på
		// forside). Kun admin (Linn) kan oprette/redigere/slette.
		match /modulbrugerLektioner/{dato} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// AI-ratings — brugere rater AI-svar 1-5 stjerner så Linn kan se
		// hvilke svar der er gode/dårlige. Brugere kan oprette/opdatere
		// deres egne ratings (uid skal matche). Admin kan læse alle.
		match /aiRatings/{ratingId} {
			allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
			allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
			allow update: if request.auth != null && resource.data.uid == request.auth.uid;
			allow delete: if isAdmin();
		}

		// Linn AI — videnbase (PDFs, slides, klient-Q&A) som AI'en bruger.
		// Alle autentificerede kan læse (worker'en læser for premium-brugere).
		// Kun admin kan uploade og slette indhold.
		match /linnAiVidenbase/{docId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Linn AI — admin-konfiguration (persona/system-prompt). Læses af
		// worker'en for at hente brugerens custom prompt. Kun admin skriver.
		match /linnAiKonfiguration/{docId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Klientspørgsmål til Linn:
		//   - Klienter kan oprette deres egne spørgsmål (uid skal matche)
		//   - Klienter kan læse SINE egne spørgsmål (for at se Linns svar)
		//   - Klienter kan IKKE læse andres spørgsmål
		//   - Admin kan læse alle og opdatere status + svar
		match /klientspoergsmaal/{spoergsmaalId} {
			allow read: if isAdmin()
				|| (request.auth != null && resource.data.uid == request.auth.uid);
			allow create: if request.auth != null
				&& request.resource.data.uid == request.auth.uid;
			allow update, delete: if isAdmin();
		}

		// Program-tildelinger — admin tildeler træningsprogrammer til kunder
		// eller forløb. Alle autentificerede kan læse (kunde-siden skal kunne
		// tjekke hvilke programmer hun har adgang til), kun admin skriver.
		match /programTildelinger/{tildelingId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// Custom-builder-tildelinger — admin giver kunder/forløb adgang til at
		// bygge eget træningsprogram. Samme adgangsmønster som programTildelinger.
		match /customBuilderTildelinger/{tildelingId} {
			allow read: if request.auth != null;
			allow write: if isAdmin();
		}

		// AllowedEmails (whitelist fra CSV-import):
		//   - Brugeren kan læse SIN egen email-record (til login-flow check)
		//   - Admin kan læse alle og skrive frit (CSV-upload, status-update)
		//   - login-flow har brug for at kunne sætte status='registered' for sin egen
		match /allowedEmails/{email} {
			allow read: if request.auth != null
				&& (isAdmin() || request.auth.token.email.lower() == email);
			allow update: if request.auth != null
				&& request.auth.token.email.lower() == email
				&& request.resource.data.diff(resource.data).affectedKeys()
					.hasOnly(['status', 'registreret']);
			allow create, delete: if isAdmin();
			allow write: if isAdmin();
		}
	}
}
