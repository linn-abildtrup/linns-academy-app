{
	"name": "linns-academy-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"seed:mikrotraening": "tsx scripts/seed-mikrotraening.ts",
		"seed:forlob": "tsx scripts/seed-forlob.ts",
		"seed:vaneprogram": "tsx scripts/seed-vaneprogram.ts",
		"seed:fodevarer": "tsx scripts/seed-fodevarer.ts",
		"seed:frida": "tsx scripts/seed-frida.ts",
		"migrate:recipes": "tsx scripts/migrate-recipes.ts",
		"cleanup:vaneprogrammer": "tsx scripts/cleanup-vaneprogrammer.ts",
		"list:forlob": "tsx scripts/list-forlob.ts",
		"upload:videos": "tsx scripts/upload-videos.ts",
		"upload:audio": "tsx scripts/upload-audio.ts",
		"reset:mikrotraening": "tsx scripts/reset-mikrotraening.ts",
		"inspect:program": "tsx scripts/inspect-program.ts",
		"generate:program": "tsx scripts/auto-generate-program.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"firebase-admin": "^13.8.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"xlsx": "^0.18.5"
	},
	"dependencies": {
		"firebase": "^12.12.1"
	}
}
